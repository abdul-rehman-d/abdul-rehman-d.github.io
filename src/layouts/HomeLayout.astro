---
import RootLayout from "./RootLayout.astro";
---

<RootLayout>
  <header>
    <h1 class="text-2xl sm:text-3xl font-bitcount">
      <a href="/" class="text-indigo-400">
        Abdul Rehman Daniyal
      </a>
    </h1>
    <p
      class="text-base sm:text-lg lg:text-xl text-neutral-400"
    >
      Software Engineer
    </p>
  </header>

  <section
    class:list={[
      "prose max-w-none prose-p:text-sm prose-p:sm:text-base prose-p:lg:text-lg prose-p:mb-4 prose-p:last:mb-0 prose-p:text-neutral-100",
      "prose-li:text-sm prose-li:sm:text-base prose-li:lg:text-lg prose-li:mb-4 prose-li:last:mb-0 prose-li:text-neutral-100",
      "prose-a:text-orange-300 prose-a:hover:text-orange-400 prose-a:underline prose-a:underline-offset-2",
    ]}
  >
    <slot />
  </section>

  <footer class="border-t py-4 text-neutral-400">
    <p class="text-xs sm:text-sm">
      © {new Date().getFullYear()} Abdul Rehman Daniyal. All rights reserved.
    </p>
  </footer>
</RootLayout>
